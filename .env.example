# Copy to .env and fill in. .env is gitignored.

# HuggingFace token — needs access to meta-llama/Llama-3.3-70B-Instruct (gated model)
# and to the viliana-dev/eval-awareness-2x2 dataset. Create at https://huggingface.co/settings/tokens
HF_TOKEN=

# Anthropic API key — needs access to Claude 3.5 Sonnet. Create at https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# Modal auth. Run `modal token new` to set this up locally (writes ~/.modal.toml),
# or set these explicitly. See https://modal.com/docs
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
